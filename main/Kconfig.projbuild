menu "Pet Project Configuration"

    config PET_WIFI_SSID
        string "WiFi SSID"
        default ""
        help
            SSID of the Wi-Fi network the pet will connect to.

    config PET_WIFI_PASSWORD
        string "WiFi Password"
        default ""
        help
            Password of the Wi-Fi network.

    config PET_WIFI_MAX_RETRY
        int "WiFi max retry count"
        default 5
        range 0 30
        help
            Maximum connection retries before giving up.

    config PET_AI_USAGE_KIMI_KEY
        string "Kimi API key (api.kimi.com)"
        default ""
        help
            Bearer token for Kimi usage API. Empty hides the AI Usage tab.

    config PET_AI_USAGE_MINIMAX_KEY
        string "MiniMax API key (www.minimaxi.com)"
        default ""
        help
            Bearer token for MiniMax usage API. Empty hides just the MiniMax card.

endmenu
